{
  "cli": {
    "version": ">= 16.20.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_NO_DETACHED": "true"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_NO_DETACHED": "true"
      },
      "node": "16"  // You can set the node version for the build environment
    }
  },
  "submit": {
    "production": {
      "releaseTrack": "production"
    }
  }
}
